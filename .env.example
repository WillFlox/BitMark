# Opción B — aliases solo Gmail (si no defines SMTP_USER / SMTP_PASSWORD):
# GMAIL_USER=tu-correo@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Remitente visible (con Gmail suele coincidir con la cuenta autenticada)
MAIL_FROM=tu-correo@gmail.com
